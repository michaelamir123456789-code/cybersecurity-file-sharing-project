"""
SIMPLE PASSWORD GENERATOR
This file creates strong random passwords for users.
It also checks how strong a password is.
"""

# TOOL 1: random - picks random letters/numbers/symbols
# Example: random.choice("abc") picks 'a' or 'b' or 'c'
import random

# TOOL 2: string - has ready-made lists of letters and numbers
# string.ascii_letters = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ"
# string.digits = "0123456789"
import string


# ================================================================
# FUNCTION 1: Generate a Random Password
# ================================================================

def generate_password(length=12, use_upper=True, use_lower=True, use_numbers=True, use_symbols=True):
    """
    Create a random password based on what the user wants.
    
    Parameters (what you can change):
    - length: how many characters (default 12, min 4, max 32)
    - use_upper: include capital letters (A-Z)
    - use_lower: include small letters (a-z)
    - use_numbers: include numbers (0-9)
    - use_symbols: include symbols (!@#$% etc.)
    
    Returns:
    - A random password as text
    """
    
    # STEP 1: Create an empty box to hold all allowed characters
    all_characters = ""
    
    # STEP 2: Add uppercase letters if user wants them
    # string.ascii_uppercase = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    if use_upper:
        all_characters = all_characters + string.ascii_uppercase
    
    # STEP 3: Add lowercase letters if user wants them
    # string.ascii_lowercase = "abcdefghijklmnopqrstuvwxyz"
    if use_lower:
        all_characters = all_characters + string.ascii_lowercase
    
    # STEP 4: Add numbers if user wants them
    # string.digits = "0123456789"
    if use_numbers:
        all_characters = all_characters + string.digits
    
    # STEP 5: Add symbols if user wants them
    # string.punctuation = "!\"#$%&'()*+,-./:;<=>?@[\\]^_`{|}~"
    if use_symbols:
        all_characters = all_characters + string.punctuation
    
    # STEP 6: Check if user selected at least one character type
    if len(all_characters) == 0:
        # If nothing selected, give a default password
        return "Default123!"
    
    # STEP 7: Create the password by picking random characters
    password_chars = []  # Start with empty list
    
    # Repeat this loop until we have enough characters
    for i in range(length):
        # Pick one random character from our character box
        random_char = random.choice(all_characters)
        # Add it to our password list
        password_chars.append(random_char)
    
    # STEP 8: Convert the list into a single string
    # Example: ['a', 'B', '5'] becomes "aB5"
    password = "".join(password_chars)
    
    # STEP 9: Return the password
    return password


# ================================================================
# FUNCTION 2: Check Password Strength
# ================================================================

def check_password_strength(password):
    """
    Check how strong a password is.
    Gives a score from 0 to 5 and tells what's missing.
    
    Parameters:
    - password: the password to check
    
    Returns:
    - score: number from 0 to 5
    - strength: words like "Weak" or "Strong"
    - feedback: list of suggestions
    """
    
    # Start with score 0 (no points yet)
    score = 0
    
    # List to store messages
    feedback = []
    
    # CHECK 1: Password length (at least 8 characters)
    if len(password) >= 8:
        score = score + 1
        feedback.append("Good: Password is long enough (8+ characters)")
    else:
        feedback.append("Bad: Password should be at least 8 characters")
    
    # CHECK 2: Has uppercase letters (A-Z)
    if any(char.isupper() for char in password):
        score = score + 1
        feedback.append("Good: Has uppercase letters")
    else:
        feedback.append("Bad: Add uppercase letters (A-Z)")
    
    # CHECK 3: Has lowercase letters (a-z)
    if any(char.islower() for char in password):
        score = score + 1
        feedback.append("Good: Has lowercase letters")
    else:
        feedback.append("Bad: Add lowercase letters (a-z)")
    
    # CHECK 4: Has numbers (0-9)
    if any(char.isdigit() for char in password):
        score = score + 1
        feedback.append("Good: Has numbers")
    else:
        feedback.append("Bad: Add numbers (0-9)")
    
    # CHECK 5: Has special symbols (!@#$% etc.)
    if any(char in string.punctuation for char in password):
        score = score + 1
        feedback.append("Good: Has special symbols")
    else:
        feedback.append("Bad: Add special symbols (!@#$% etc.)")
    
    # Decide strength level based on score
    if score >= 5:
        strength = "Very Strong"
    elif score >= 4:
        strength = "Strong"
    elif score >= 3:
        strength = "Medium"
    elif score >= 2:
        strength = "Weak"
    else:
        strength = "Very Weak"
    
    # Return all information as a dictionary
    return {
        'score': score,
        'max_score': 5,
        'strength': strength,
        'feedback': feedback
    }


